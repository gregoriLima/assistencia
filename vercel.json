{
	"cleanUrls": true,
	"trailingSlash": false,
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				}
			]
		}
	],
	"rewrites": [
		{
			"source": "/email",
			"destination": "/"
		},
		{
			"source": "/assistencia",
			"destination": "/"
		}
	]
}